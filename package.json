{
  "name": "vicoop-bridge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:server": "pnpm --filter @vicoop-bridge/server dev",
    "dev:client": "pnpm --filter @vicoop-bridge/client dev",
    "deploy:server": "fly deploy -c packages/server/fly.toml ."
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
